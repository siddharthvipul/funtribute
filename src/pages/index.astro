---
import Base from '../layouts/Base.astro';
import { projects } from '../data/load-projects';

const totalIssues = projects.reduce((sum, p) => sum + p.openIssueCount, 0);
const totalGoodFirst = projects.reduce((sum, p) => sum + p.goodFirstIssuesList.length, 0);
---

<Base title="Home">
  <section class="bg-gradient-to-br from-unicef-dark to-unicef-blue text-white py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        Contribute to open source that matters
      </h1>
      <p class="text-lg md:text-xl text-blue-100 max-w-2xl mx-auto mb-10">
        Discover UNICEF open source projects and find the right way to contribute — whether you write code, design, translate, or test.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/wizard"
          class="inline-block bg-white text-unicef-dark font-semibold px-8 py-4 rounded-lg hover:bg-blue-50 transition-colors text-lg"
        >
          I'm new to open source
        </a>
        <a
          href="/browse"
          class="inline-block border-2 border-white text-white font-semibold px-8 py-4 rounded-lg hover:bg-white/10 transition-colors text-lg"
        >
          Browse projects
        </a>
      </div>
    </div>
  </section>

  <section class="bg-white border-b border-gray-200">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <div class="grid grid-cols-3 gap-4 text-center">
        <div>
          <p class="text-3xl font-bold text-unicef-dark">{projects.length}</p>
          <p class="text-sm text-gray-500 mt-1">Projects</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-unicef-dark">{totalIssues}</p>
          <p class="text-sm text-gray-500 mt-1">Open Issues</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-unicef-dark">{totalGoodFirst}</p>
          <p class="text-sm text-gray-500 mt-1">Good First Issues</p>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-16">
    <h2 class="text-2xl font-bold text-center mb-10">Why contribute?</h2>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="w-14 h-14 bg-unicef-blue/10 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-unicef-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="font-semibold text-lg mb-2">Real-world impact</h3>
        <p class="text-gray-600 text-sm">
          Your contributions directly support UNICEF's mission to improve the lives of children worldwide through technology.
        </p>
      </div>
      <div class="text-center">
        <div class="w-14 h-14 bg-unicef-blue/10 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-unicef-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
        </div>
        <h3 class="font-semibold text-lg mb-2">Grow your skills</h3>
        <p class="text-gray-600 text-sm">
          Work on production-grade software across diverse tech stacks. Build your portfolio with meaningful open source contributions.
        </p>
      </div>
      <div class="text-center">
        <div class="w-14 h-14 bg-unicef-blue/10 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-unicef-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
        </div>
        <h3 class="font-semibold text-lg mb-2">Join a community</h3>
        <p class="text-gray-600 text-sm">
          Connect with developers, designers, and changemakers around the world who share your passion for social good.
        </p>
      </div>
    </div>
  </section>
</Base>
