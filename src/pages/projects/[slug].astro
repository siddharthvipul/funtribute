---
import Base from '../../layouts/Base.astro';
import { projects } from '../../data/load-projects';
import { getSDG } from '../../data/sdgs';
import type { Project } from '../../types';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props as { project: Project };

const repoUrl = project.platform === 'github'
  ? `https://github.com/${project.github}`
  : `https://gitlab.com/${project.github}`;

const contributingUrl = project.platform === 'github'
  ? `https://github.com/${project.github}/blob/main/CONTRIBUTING.md`
  : repoUrl;

const base = import.meta.env.BASE_URL;
---

<Base title={project.name} description={project.description}>
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-4xl mx-auto px-4 py-8">
      <div class="flex items-start justify-between mb-4">
        <div>
          <a href={`${base}browse`} class="text-sm text-gray-500 hover:text-[#1cabe2] mb-2 inline-block">&larr; Back to projects</a>
          <h1 class="text-3xl font-bold">{project.name}</h1>
        </div>
        <span class={`text-sm font-medium px-3 py-1 rounded-full ${
          project.category === 'unicef'
            ? 'bg-blue-100 text-blue-700'
            : 'bg-purple-100 text-purple-700'
        }`}>
          {project.category === 'unicef' ? 'UNICEF' : 'Venture Fund'}
        </span>
      </div>
      <p class="text-lg text-gray-600">{project.description}</p>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 py-8 space-y-8">
    <!-- SDGs -->
    <section>
      <h2 class="text-lg font-semibold mb-3">Sustainable Development Goals</h2>
      <div class="flex flex-wrap gap-3">
        {project.sdgs.map((sdgNum) => {
          const sdg = getSDG(sdgNum);
          return sdg && (
            <div class="flex items-center gap-2 bg-white border border-gray-200 rounded-lg px-3 py-2">
              <span
                class="w-8 h-8 rounded flex items-center justify-center text-white text-sm font-bold"
                style={`background-color: ${sdg.color}`}
              >
                {sdg.number}
              </span>
              <div>
                <span class="text-sm font-medium">{sdg.name}</span>
                <span class="block text-xs text-gray-500">{sdg.shortDescription}</span>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Tech Stack -->
    <section>
      <h2 class="text-lg font-semibold mb-3">Tech Stack</h2>
      <div class="flex flex-wrap gap-2">
        {project.tech.map((t) => (
          <span class="bg-gray-100 text-gray-700 px-3 py-1 rounded-full text-sm font-medium">{t}</span>
        ))}
      </div>
    </section>

    <!-- Stats -->
    {(project.stars > 0 || project.openIssueCount > 0) && (
      <section>
        <h2 class="text-lg font-semibold mb-3">Project Activity</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {project.stars > 0 && (
            <div class="bg-white border border-gray-200 rounded-lg p-4 text-center">
              <p class="text-2xl font-bold text-gray-900">{project.stars}</p>
              <p class="text-sm text-gray-500">Stars</p>
            </div>
          )}
          {project.forks > 0 && (
            <div class="bg-white border border-gray-200 rounded-lg p-4 text-center">
              <p class="text-2xl font-bold text-gray-900">{project.forks}</p>
              <p class="text-sm text-gray-500">Forks</p>
            </div>
          )}
          {project.contributorCount > 0 && (
            <div class="bg-white border border-gray-200 rounded-lg p-4 text-center">
              <p class="text-2xl font-bold text-gray-900">{project.contributorCount}</p>
              <p class="text-sm text-gray-500">Contributors</p>
            </div>
          )}
          {project.openIssueCount > 0 && (
            <div class="bg-white border border-gray-200 rounded-lg p-4 text-center">
              <p class="text-2xl font-bold text-gray-900">{project.openIssueCount}</p>
              <p class="text-sm text-gray-500">Open Issues</p>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- Links -->
    <section>
      <h2 class="text-lg font-semibold mb-3">Links</h2>
      <div class="flex flex-wrap gap-3">
        <a
          href={repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-gray-900 text-white px-4 py-2 rounded-lg hover:bg-gray-800 text-sm"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          {project.platform === 'github' ? 'GitHub' : 'GitLab'}
        </a>
        {project.website && (
          <a
            href={project.website}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 border border-gray-300 px-4 py-2 rounded-lg hover:bg-gray-50 text-sm"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            Website
          </a>
        )}
        <a
          href={contributingUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border border-gray-300 px-4 py-2 rounded-lg hover:bg-gray-50 text-sm"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          Contributing Guide
        </a>
      </div>
    </section>

    <!-- Good First Issues -->
    {project.goodFirstIssuesList.length > 0 && (
      <section>
        <h2 class="text-lg font-semibold mb-3">
          Good First Issues
          <span class="text-sm font-normal text-gray-500 ml-2">({project.goodFirstIssuesList.length})</span>
        </h2>
        <div class="space-y-2">
          {project.goodFirstIssuesList.map((issue) => (
            <a
              href={issue.url}
              target="_blank"
              rel="noopener noreferrer"
              class="block bg-white border border-gray-200 rounded-lg p-3 hover:border-green-300 hover:bg-green-50/50 transition-colors"
            >
              <span class="text-sm font-medium text-gray-900">{issue.title}</span>
              <div class="flex gap-2 mt-1">
                {issue.labels.map((label) => (
                  <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full">{label}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Help Wanted Issues -->
    {project.helpWantedIssuesList.length > 0 && (
      <section>
        <h2 class="text-lg font-semibold mb-3">
          Help Wanted
          <span class="text-sm font-normal text-gray-500 ml-2">({project.helpWantedIssuesList.length})</span>
        </h2>
        <div class="space-y-2">
          {project.helpWantedIssuesList.map((issue) => (
            <a
              href={issue.url}
              target="_blank"
              rel="noopener noreferrer"
              class="block bg-white border border-gray-200 rounded-lg p-3 hover:border-yellow-300 hover:bg-yellow-50/50 transition-colors"
            >
              <span class="text-sm font-medium text-gray-900">{issue.title}</span>
              <div class="flex gap-2 mt-1">
                {issue.labels.map((label) => (
                  <span class="text-xs bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded-full">{label}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="bg-gradient-to-r from-[#374ea2] to-[#1cabe2] rounded-xl p-8 text-center text-white">
      <h2 class="text-xl font-bold mb-2">Ready to contribute?</h2>
      <p class="text-blue-100 mb-6">Check out the repository and find an issue to work on</p>
      <a
        href={repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-white text-[#374ea2] font-semibold px-8 py-3 rounded-lg hover:bg-blue-50 transition-colors"
      >
        Start Contributing
      </a>
    </section>
  </div>
</Base>
